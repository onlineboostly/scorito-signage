{
  "name": "scorito-signage",
  "version": "0.1.0",
  "private": true,
  "description": "Scorito pool standing + today's matches on a digital signage screen (OptiSigns). Scraped via GitHub Actions, stored in Supabase, rendered by Next.js on Vercel.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "scrape": "tsx scraper/scrape.ts",
    "scrape:discover": "tsx scraper/scrape.ts --discover",
    "seed": "tsx scraper/seed.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "next": "^14.2.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "dotenv": "^16.4.5",
    "playwright": "^1.46.0",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.10",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4"
  }
}
