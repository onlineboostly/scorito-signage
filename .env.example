# ── Scraper (GitHub Actions secrets + local .env.local) ─────────────────────
SCORITO_EMAIL=
SCORITO_PASSWORD=
# The two logged-in Scorito pages to scrape:
SCORITO_STANDING_URL=
SCORITO_MATCHES_URL=
POOL_ID=wk2026
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Optional: days of snapshot history to keep (default 7)
# RETENTION_DAYS=7

# ── Next.js app (Vercel env vars + local .env.local) ────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional: pool that "/" redirects to (default wk2026)
# NEXT_PUBLIC_DEFAULT_POOL_ID=wk2026
